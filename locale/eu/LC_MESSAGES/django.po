#: templates/pages/team.html:187
msgid ""
"Sendaoroi cuenta con la colaboración de entidades y profesionales que "
"refuerzan el acompañamiento psicológico, comunitario y restaurativo del "
"programa."
msgstr ""
"Sendaoroi programaren laguntza psikologikoa, komunitarioa eta "
"zaharberritzailea indartzen duten entitate eta profesionalen lankidetza du."

